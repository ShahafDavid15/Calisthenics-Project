# ============================================================
#  Copy this file to .env and fill in your values
#  cp .env.example .env
# ============================================================

# --- Server ---
PORT=3002
NODE_ENV=development

# --- Database (MySQL) ---
# Prefer 127.0.0.1 on Windows (Node may resolve "localhost" to IPv6 ::1; Docker often listens on IPv4 only).
DB_HOST=127.0.0.1
DB_USER=root
# Docker Compose (this repo): default is rootpass unless you override MYSQL_ROOT_PASSWORD.
# XAMPP: often leave empty.
DB_PASSWORD=your_mysql_password
DB_NAME=calisthenics

# --- JWT ---
# Generate a strong random secret, e.g.: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your_jwt_secret_here

# --- Email (Gmail + App Password) ---
# Enable 2FA on your Gmail, then create an App Password at:
# https://myaccount.google.com/apppasswords
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_gmail_app_password

# --- CORS ---
ALLOWED_ORIGINS=http://localhost:3000

# --- PayPal (Sandbox) ---
# Create a sandbox app at https://developer.paypal.com/dashboard/applications/sandbox
# Client Authentication failed = wrong secret, wrong env (sandbox vs live), or ID+secret from different apps.
PAYPAL_ENV=sandbox
PAYPAL_CLIENT_ID=your_paypal_sandbox_client_id
PAYPAL_CLIENT_SECRET=your_paypal_sandbox_client_secret
# Optional: override currency (must match PayPal account + SDK). Default: ILS (same as ₪ on purchase page).
# If Sandbox rejects ILS: PAYPAL_CURRENCY=USD
# PAYPAL_CURRENCY=ILS
