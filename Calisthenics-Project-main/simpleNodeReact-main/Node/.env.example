# ============================================================
#  Copy this file to .env and fill in your values
#  cp .env.example .env
# ============================================================

# --- Server ---
PORT=3002
NODE_ENV=development

# --- Database (MySQL) ---
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=your_mysql_password
DB_NAME=calisthenics

# --- JWT ---
# Generate a strong random secret, e.g.: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your_jwt_secret_here

# --- Email (Gmail + App Password) ---
# Enable 2FA on your Gmail, then create an App Password at:
# https://myaccount.google.com/apppasswords
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_gmail_app_password

# --- CORS ---
ALLOWED_ORIGINS=http://localhost:3000

# --- PayPal (Sandbox) ---
# Create a sandbox app at https://developer.paypal.com/
PAYPAL_CLIENT_ID=your_paypal_sandbox_client_id
PAYPAL_CLIENT_SECRET=your_paypal_sandbox_client_secret
