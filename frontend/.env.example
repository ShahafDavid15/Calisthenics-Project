# Copy to .env in this folder (Create React App reads it on startup).
# Restart npm start after any change.

# Optional: same Sandbox Client ID as backend PAYPAL_CLIENT_ID (if omitted, app loads it from the backend)
REACT_APP_PAYPAL_CLIENT_ID=your_paypal_sandbox_client_id

# Optional: must match backend PAYPAL_CURRENCY (default ILS). Only needed if SDK loads before API / offline.
# REACT_APP_PAYPAL_CURRENCY=ILS

# Optional: API base URL if you do not use the dev proxy in package.json (default: empty = relative /proxy)
# REACT_APP_API_URL=http://localhost:3002
